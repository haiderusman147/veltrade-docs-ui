{
  "name": "veltrade-docs-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "adsense:audit": "npm run build && npm run start -- -p 3000 & wait-on http://localhost:3000 && npm run adsense:links && npm run adsense:lighthouse && npm run adsense:placeholders",
    "adsense:links": "blc http://localhost:3000 -ro --filter-level 3",
    "adsense:lighthouse": "lighthouse http://localhost:3000 --only-categories=performance,accessibility,best-practices,seo --output=html --output-path=./adsense-lighthouse.html --chrome-flags='--headless'",
    "adsense:placeholders": "node ./scripts/adsense-placeholders.mjs"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.1.6",
    "gray-matter": "^4.0.3",
    "next": "16.1.6",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "reading-time": "^1.5.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.1.6",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "broken-link-checker": "^0.7.8",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.1.6",
    "lighthouse": "^13.0.3",
    "tailwindcss": "^4",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  }
}
